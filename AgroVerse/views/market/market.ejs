<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Market Price Checker</title>

  <!-- Font Awesome for icons -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

  <!-- Custom CSS -->
  <link rel="stylesheet" href="/css/market.css">
</head>
<body>

<div class="mp-overlay">

  <div class="mp-container">

    <h2 class="mp-title">Market Price Checker</h2>
    <p class="mp-subtitle">Check latest crop prices in different states</p>

    <!-- Crop Selection -->
    <div class="mp-crop-selection">
      <input type="text" class="mp-crop-search" placeholder="Type crop name..." />
      <div class="mp-crop-cards">
        <div class="mp-crop-card" data-crop="Rice"><img src="/images/rice.jpg" alt="Rice">Rice 🌾</div>
        <div class="mp-crop-card" data-crop="Wheat"><img src="/images/wheat.jpg" alt="Wheat">Wheat 🌾</div>
        <div class="mp-crop-card" data-crop="Maize"><img src="/images/corn.jpg" alt="Maize">Maize 🌽</div>
        <div class="mp-crop-card" data-crop="Cotton"><img src="/images/cotton.jpg" alt="Cotton">Cotton 🌿</div>
        <div class="mp-crop-card" data-crop="Onion"><img src="/images/onion.jpg" alt="Onion">Onion 🧅</div>
      </div>
    </div>

    <!-- State Selection Form -->
    <form class="mp-form" action="/market/check" method="POST">
      <span class="mp-close-btn" onclick="window.location='/'">✖</span>
      <div class="mp-input-group">
        <label for="state">Select State</label>
        <select class="mp-state-select" name="state">
          <option value="Maharashtra">Maharashtra</option>
          <option value="Punjab">Punjab</option>
          <option value="Karnataka">Karnataka</option>
          <option value="Gujarat">Gujarat</option>
        </select>
      </div>
      <input type="hidden" name="crop" class="mp-selected-crop">
      <button class="mp-btn" type="submit">Check Price</button>
    </form>

    <!-- RESULT SECTION -->
    <div class="mp-result-section" style="<%= result ? 'display:flex;' : 'display:none;' %>">
      <% if(result && result.length > 0){ %>
        <h3>📊 Market Prices</h3>
        <p><strong>Crop:</strong> <%= crop %> | <strong>State:</strong> <%= state %></p>

        <div class="mp-best-market-card">
          ⭐ Best Market: <%= bestMarket.market %> - ₹ <%= bestMarket.modal_price %>
        </div>

        <div class="mp-mandi-cards">
          <% result.forEach(item => { %>
            <div class="mp-mandi-card <%= item.market === bestMarket.market ? 'best' : '' %>">
              <h4><%= item.market %></h4>
              <p>Min: ₹ <%= item.min_price %></p>
              <p>Max: ₹ <%= item.max_price %></p>
              <p>Modal: ₹ <%= item.modal_price %></p>
            </div>
          <% }) %>
        </div>

        <canvas id="mpPriceChart" width="400" height="200"></canvas>
      <% } else if(result){ %>
        <p style="color:red;">No data available for selected crop and state.</p>
      <% } %>
    </div>

  </div>
</div>

<!-- Chart.js -->
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
  // Crop card selection
  const cropCards = document.querySelectorAll('.mp-crop-card');
  const selectedCropInput = document.querySelector('.mp-selected-crop');
  const cropSearchInput = document.querySelector('.mp-crop-search');

  cropCards.forEach(card => {
    card.addEventListener('click', () => {
      cropCards.forEach(c => c.classList.remove('selected'));
      card.classList.add('selected');
      selectedCropInput.value = card.dataset.crop;
    });
  });

  // Autocomplete filter
  cropSearchInput.addEventListener('input', () => {
    const term = cropSearchInput.value.toLowerCase();
    cropCards.forEach(card => {
      card.style.display = card.dataset.crop.toLowerCase().includes(term) ? "flex" : "none";
    });
  });

  // Chart
  const resultData = <%- JSON.stringify(result || []) %>;
  if(resultData.length > 0){
    const ctx = document.getElementById('mpPriceChart').getContext('2d');
    const labels = resultData.map(item => item.market);
    const modalPrices = resultData.map(item => parseInt(item.modal_price));
    const bgColors = modalPrices.map((_, i) => `hsl(${i * 50 % 360}, 70%, 60%)`);
    const borderColors = modalPrices.map((_, i) => `hsl(${i * 50 % 360}, 70%, 40%)`);

    new Chart(ctx, {
      type: 'bar',
      data: {
        labels: labels,
        datasets: [{
          label: 'Modal Price (₹/Quintal)',
          data: modalPrices,
          backgroundColor: bgColors,
          borderColor: borderColors,
          borderWidth: 1
        }]
      },
      options: {
        plugins: { legend: { display: false } },
        scales: { y: { beginAtZero: true } }
      }
    });
  }
</script>

</body>
</html>