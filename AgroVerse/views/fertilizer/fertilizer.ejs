<div class="center-page">
  <div class="fertilizer-card">

    <!-- Page Heading -->
    <h2 id="fertilizer-heading">Fertilizer Recommendation</h2>

    <!-- Fertilizer Form -->
    <form id="fertilizer-form" action="/fertilizer/recommend" method="POST">
      <span class="close-btn" onclick="window.location='/'">✖</span>

      <label for="crop-select">Select Crop</label>
      <select id="crop-select" name="crop">
        <option value="rice">Rice</option>
        <option value="wheat">Wheat</option>
        <option value="maize">Maize</option>
        <option value="cotton">Cotton</option>
        <option value="sugarcane">Sugarcane</option>
        <option value="soybean">Soybean</option>
        <option value="tomato">Tomato</option>
        <option value="potato">Potato</option>
        <option value="onion">Onion</option>
        <option value="chili">Chili</option>
      </select>

      <label for="soil-select">Select Soil Type</label>
      <select id="soil-select" name="soil">
        <option value="clay">Clay Soil</option>
        <option value="sandy">Sandy Soil</option>
        <option value="loamy">Loamy Soil</option>
        <option value="silt">Silt Soil</option>
        <option value="black">Black Soil</option>
        <option value="red">Red Soil</option>
      </select>

      <button id="get-recommendation" type="submit">Get Recommendation</button>

    </form>

    <!-- Recommendation Result -->
    <% if (result) { %>
      <div id="recommendation-result" class="recommendation">

        <h3 id="result-heading">🌱 Fertilizer Recommendation</h3>

        <p><strong>Crop:</strong> <span id="result-crop"><%= result.crop %></span></p>
        <p><strong>Soil Type:</strong> <span id="result-soil"><%= result.soil %></span></p>
        <p><strong>Recommended Fertilizer:</strong> <span id="result-fertilizer"><%= result.fertilizer %></span></p>

        <hr>

        <p><strong>Nutrients Provided:</strong> <span id="result-nutrients"><%= result.nutrients %></span></p>
        <p><strong>Quantity:</strong> <span id="result-quantity"><%= result.quantity %></span></p>
        <p><strong>Benefits:</strong> <span id="result-benefits"><%= result.benefit %></span></p>

      </div>
    <% } %>

  </div>
</div>