<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>AgroVerse - Government Schemes</title>
<!-- Bootstrap CSS -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
<style>
  body { background-color: #f8f9fa; }
  .card {
    border-radius: 15px;
    overflow: hidden;
    transition: transform 0.3s, box-shadow 0.3s;
    background: linear-gradient(145deg, #ffffff, #f1f3f6);
    cursor: pointer;
  }
  .card:hover {
    transform: translateY(-8px);
    box-shadow: 0 15px 25px rgba(0,0,0,0.15);
  }
  .card-img-top { max-height: 150px; object-fit: cover; transition: transform 0.3s; }
  .card-img-top:hover { transform: scale(1.05); }
  .compensation-card { background: linear-gradient(145deg, #ffe5d1, #ffcc99); }
  .badge-category {
    position: absolute;
    top: 10px;
    right: 10px;
    font-size: 0.8rem;
  }
  .nav-pills .nav-link { font-weight: 500; }
</style>
</head>
<body>

<div class="container my-5">
  <h2 class="mb-4 text-center">Government Schemes</h2>

  <!-- Category Tabs -->
  <ul class="nav nav-pills justify-content-center mb-4" id="schemeCategories" role="tablist">
    <% categories.forEach((cat, idx) => { %>
      <li class="nav-item" role="presentation">
        <button class="nav-link <%= idx===0 ? 'active' : '' %>" data-bs-toggle="tab" data-bs-target="#cat<%= idx %>">
          <%= cat %>
        </button>
      </li>
    <% }) %>
  </ul>

  <!-- Tab Content -->
  <div class="tab-content">
    <% categories.forEach((cat, idx) => { %>
      <div class="tab-pane fade <%= idx===0 ? 'show active' : '' %>" id="cat<%= idx %>">
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
          <% schemes.filter(s => s.category === cat).forEach(scheme => { %>
            <div class="col">
              <div class="card <%= scheme.category === 'Compensation' ? 'compensation-card' : '' %>" data-bs-toggle="modal" data-bs-target="#schemeModal<%= scheme.id %>">
                <span class="badge bg-primary badge-category"><%= scheme.category %></span>
                <img src="/images/<%= scheme.image %>" class="card-img-top" alt="<%= scheme.name %>">
                <div class="card-body">
                  <h5 class="card-title"><i class="<%= scheme.icon %> text-success"></i> <%= scheme.name %></h5>
                  <p class="card-text"><%= scheme.shortDesc %></p>
                </div>
              </div>
            </div>

            <!-- Modal for full info -->
            <div class="modal fade" id="schemeModal<%= scheme.id %>" tabindex="-1">
              <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content">
                  <div class="modal-header">
                    <h5 class="modal-title"><%= scheme.name %></h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                  </div>
                  <div class="modal-body">
                    <img src="/images/<%= scheme.image %>" class="img-fluid mb-3" alt="<%= scheme.name %>">
                    <p><strong>Category:</strong> <%= scheme.category %></p>
                    <p><strong>State:</strong> <%= scheme.state %></p>
                    <p><strong>Eligibility:</strong> <%= scheme.eligibility %></p>
                    <p><%= scheme.fullDesc %></p>
                  </div>
                  <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                  </div>
                </div>
              </div>
            </div>

          <% }) %>
        </div>
      </div>
    <% }) %>
  </div>

</div>

<!-- Bootstrap JS -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>